<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IITK Foundation for Medical Research & Technology</title>
    <link rel="icon" type="image/png" href="/images/fmrt.png">
    
    <!-- Swiper.js -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>

    <!-- Extracted CSS & Logic -->
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/main.js" defer></script>

    <!-- Tailwind CSS Engine for Layouts -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        iitkNavy: '#002B6B',
                        iitkTeal: '#0052CC',
                        hospitalLight: '#F4F7F9',
                        iitkbluelight: '#60AEFF',
                    }
                }
            }
        }
    </script>
</head>
<body class="flex flex-col min-h-screen overflow-x-hidden">

    <!-- Top Utility Bar -->
    <div class="bg-iitkNavy text-gray-300 py-2.5 px-4 md:px-16 text-[11px] font-medium tracking-wider flex flex-col sm:flex-row justify-between items-center z-50 relative border-b border-white/10 gap-2 sm:gap-0">
        <span class="text-center sm:text-left">📍 IIT Kanpur Campus, Kalyanpur, Kanpur – 208 016, Uttar Pradesh, India</span>
        <div class="flex flex-wrap justify-center gap-5">
            <a href="tel:+917525031033" class="hover:text-iitkbluelight transition-colors flex items-center gap-1.5">
                <span>📞</span> +91-75250-31033
            </a>
            <a href="mailto:admin1_fmrt@iitk.ac.in" class="hover:text-iitkbluelight transition-colors flex items-center gap-1.5">
                <span>✉</span> admin1_fmrt@iitk.ac.in
            </a>
            <a href="https://iitk.ac.in/" target="_blank" class="hover:text-iitkbluelight transition-colors flex items-center gap-1.5 border-l border-white/20 pl-4">
                <span>🌐</span> IITK Main
            </a>
        </div>
    </div>

    <!-- Main Header Navigation (z-[1000] keeps the X button clickable) -->
    <header class="bg-white w-full z-[1000] px-4 sm:px-8 md:px-16 py-4 flex justify-between items-center shadow-sm sticky top-0 relative">
        <a href="/" class="flex items-center gap-4 group">
            <img src="/images/fmrt.png" alt="FMRT Logo" class="h-12 md:h-16 w-auto object-contain transition-transform duration-300 group-hover:scale-105">
            <div class="leading-tight">
                <h1 class="font-heading text-base md:text-xl font-extrabold text-iitkNavy tracking-tight">
                    IITK Foundation
                </h1>
                <p class="text-[11px] md:text-xs text-gray-500 font-semibold tracking-wide uppercase">
                    for Medical Research & Technology
                </p>
            </div>
        </a>
        
        <!-- Desktop Navigation Menu -->
        <nav class="hidden lg:flex gap-8 text-[#1E293B] font-bold text-xs tracking-widest uppercase items-center">
            <a href="/" class="hover:text-iitkTeal transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-iitkTeal hover:after:w-full after:transition-all">Home</a>
            <a href="/about" class="hover:text-iitkTeal transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-iitkTeal hover:after:w-full after:transition-all">About</a>
            <a href="/news" class="hover:text-iitkTeal transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-iitkTeal hover:after:w-full after:transition-all">News</a>
            <a href="/careers" class="hover:text-iitkTeal transition-colors relative py-2 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-[2px] after:bg-iitkTeal hover:after:w-full after:transition-all">Careers</a>
            <a href="/contact" class="btn-primary rounded-lg bg-gradient-to-r from-[#063f8e] to-[#207ce5] text-white shadow-lg shadow-[#207ce5]/40 rounded-full px-6 py-2 font-bold px-5 py-3 shadow-md">Contact Us →</a>
        </nav>

        <!-- Mobile Drawer Toggle Button -->
        <button id="mobileMenuBtn" class="lg:hidden text-iitkNavy focus:outline-none p-2 rounded-lg hover:bg-gray-100 transition-colors" aria-label="Toggle Menu">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path id="menuIcon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </header>

    <!-- Mobile Drawer Container Menu (FIXED: Added pt-36 to push content safely below header) -->
    <div id="mobileMenu" class="hidden fixed inset-0 w-full h-screen bg-[#FAFAFA] z-[990] flex flex-col px-6 pt-36 pb-32 gap-4 overflow-y-auto">
        
        <a href="/" class="bg-white rounded-[1.25rem] py-5 px-8 text-xl font-bold text-iitkNavy shadow-[0_2px_10px_rgba(0,0,0,0.03)] border border-gray-100 hover:border-iitkTeal hover:text-iitkTeal transition-all">
            Home
        </a>
        
        <a href="/about" class="bg-white rounded-[1.25rem] py-5 px-8 text-xl font-bold text-iitkNavy shadow-[0_2px_10px_rgba(0,0,0,0.03)] border border-gray-100 hover:border-iitkTeal hover:text-iitkTeal transition-all">
            About
        </a>
        
        <a href="/news" class="bg-white rounded-[1.25rem] py-5 px-8 text-xl font-bold text-iitkNavy shadow-[0_2px_10px_rgba(0,0,0,0.03)] border border-gray-100 hover:border-iitkTeal hover:text-iitkTeal transition-all">
            News
        </a>
        
        <a href="/careers" class="bg-white rounded-[1.25rem] py-5 px-8 text-xl font-bold text-iitkNavy shadow-[0_2px_10px_rgba(0,0,0,0.03)] border border-gray-100 hover:border-iitkTeal hover:text-iitkTeal transition-all">
            Careers
        </a>
        
        <a href="/contact" class="bg-iitkTeal text-white rounded-[1.25rem] py-5 px-8 text-xl font-bold shadow-[0_4px_14px_rgba(0,133,126,0.3)] hover:bg-iitkNavy transition-all mt-4 text-center">
            Contact Us
        </a>

        <!-- Fallback UX Close Button -->
        <button id="closeMenuFallback" class="mt-4 text-gray-400 font-bold text-sm tracking-widest uppercase hover:text-iitkNavy transition-colors text-center w-full py-4">
            
        </button>

    </div>