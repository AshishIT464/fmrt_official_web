<%- include('partials/header') %>

<section class="relative w-full min-h-[60vh] sm:min-h-[65vh] lg:h-[75vh] flex items-end pb-12 sm:pb-16 px-4 sm:px-8 lg:px-24 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2070&auto=format&fit=crop" alt="Medical News Context" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-iitkNavy via-iitkNavy/50 to-transparent"></div>
    </div>

    <div class="relative z-10 w-full max-w-4xl p-6 sm:p-10 lg:p-12 glass-panel">
        <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-iitkbluelight mb-4">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            <div class="w-4 h-[1px] bg-white/40"></div>
            <span class="text-white">News & Updates</span>
        </div>
        <h1 class="font-heading text-3xl sm:text-5xl lg:text-6xl font-black text-white mb-4 tracking-tight">News & Updates</h1>
        <p class="text-sm sm:text-lg text-gray-100 font-light leading-relaxed max-w-2xl">
            Latest developments, milestones, research breakthroughs, and announcements from FMRT and the Gangwal School.
        </p>
    </div>
</section>

<section class="py-16 sm:py-24 px-4 sm:px-8 lg:px-24 max-w-5xl mx-auto">
    <div class="space-y-12 sm:space-y-16">
        
        <article class="flex flex-col md:flex-row gap-4 md:gap-8 items-start border-b border-gray-200 pb-10">
            <div class="w-full md:w-1/4 shrink-0">
                <span class="bg-iitkTeal text-white text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded mb-2 inline-block">Media Feature</span>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">October 2025</p>
            </div>
            <div class="w-full md:w-3/4">
                <h3 class="font-heading font-bold text-xl text-iitkNavy mb-3 hover:text-iitkTeal transition-colors">GSMST Featured in CASE.org: "Transforming Lives" — A Story of IIT Kanpur's Medical Ambition</h3>
                <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4">The Gangwal School's vision and progress were featured globally, highlighting how IIT Kanpur is building the first-of-its-kind medical school in India where innovation is led by the marriage of medical research and engineering.</p>
                <a href="https://www.case.org/resources/issues/september-october-2025/transforming-lives" target="_blank" class="text-iitkTeal font-bold uppercase text-[11px] tracking-wider hover:underline">Source: CASE.org →</a>
            </div>
        </article>

        <article class="flex flex-col md:flex-row gap-4 md:gap-8 items-start border-b border-gray-200 pb-10">
            <div class="w-full md:w-1/4 shrink-0">
                <span class="bg-iitkTeal text-white text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded mb-2 inline-block">Media Coverage</span>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">June 2024</p>
            </div>
            <div class="w-full md:w-3/4">
                <h3 class="font-heading font-bold text-xl text-iitkNavy mb-3 hover:text-iitkTeal transition-colors">GSMST Featured in The Week Magazine — June 2024 Edition</h3>
                <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4">The Gangwal School of Medical Sciences and Technology received national coverage in The Week Magazine, spotlighting its pioneering approach to MedTech innovation and affordable healthcare delivery.</p>
                <a href="https://www.theweek.in" target="_blank" class="text-iitkTeal font-bold uppercase text-[11px] tracking-wider hover:underline">Source: The Week →</a>
            </div>
        </article>

        <article class="flex flex-col md:flex-row gap-4 md:gap-8 items-start border-b border-gray-200 pb-10">
            <div class="w-full md:w-1/4 shrink-0">
                <span class="bg-iitkTeal text-white text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded mb-2 inline-block">Partnership</span>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">2024</p>
            </div>
            <div class="w-full md:w-3/4">
                <h3 class="font-heading font-bold text-xl text-iitkNavy mb-3 hover:text-iitkTeal transition-colors">IIT Kanpur Signs MoU with ICICI Foundation for Digital Health Stack</h3>
                <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4">A landmark agreement to build a Digital Health Stack that will improve public healthcare using medical technology, AI-based diagnostics, and enhanced point-of-care services across India.</p>
                <a href="https://www.icici.bank.in" target="_blank" class="text-iitkTeal font-bold uppercase text-[11px] tracking-wider hover:underline">Source: IIT Kanpur →</a>
            </div>
        </article>

        <article class="flex flex-col md:flex-row gap-4 md:gap-8 items-start border-b border-gray-200 pb-10">
            <div class="w-full md:w-1/4 shrink-0">
                <span class="bg-iitkTeal text-white text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded mb-2 inline-block">Research</span>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">2024</p>
            </div>
            <div class="w-full md:w-3/4">
                <h3 class="font-heading font-bold text-xl text-iitkNavy mb-3 hover:text-iitkTeal transition-colors">GSMST Hosts Colloquium on Combating Antimicrobial Resistance (AMR)</h3>
                <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4">A joint online research colloquium explored biological and chemical strategies to combat AMR — one of the world's most pressing healthcare challenges — bringing together experts from multiple institutions.</p>
                <a href="https://www.iitk.ac.in" target="_blank" class="text-iitkTeal font-bold uppercase text-[11px] tracking-wider hover:underline">Source: IIT Kanpur →</a>
            </div>
        </article>

        <article class="flex flex-col md:flex-row gap-4 md:gap-8 items-start">
            <div class="w-full md:w-1/4 shrink-0">
                <span class="bg-iitkTeal text-white text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded mb-2 inline-block">Milestone</span>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">July 16, 2022</p>
            </div>
            <div class="w-full md:w-3/4">
                <h3 class="font-heading font-bold text-xl text-iitkNavy mb-3 hover:text-iitkTeal transition-colors">Foundation Stone Laid by Union Education Minister Shri Dharmendra Pradhan</h3>
                <p class="text-gray-600 text-xs sm:text-sm leading-relaxed mb-4">A landmark ceremony marking the official start of construction for the Gangwal School of Medical Sciences and Technology and the Yadupati Singhania Super Specialty Hospital on the IIT Kanpur campus.</p>
                <a href="https://www.iitk.ac.in" target="_blank" class="text-iitkTeal font-bold uppercase text-[11px] tracking-wider hover:underline">Source: IIT Kanpur Press Release →</a>
            </div>
        </article>
    </div>
</section>

<%- include('partials/footer') %>