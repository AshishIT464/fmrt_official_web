<%- include('partials/header') %>

<section class="relative min-h-[70vh] sm:min-h-[75vh] lg:min-h-[85vh] flex items-center overflow-hidden bg-iitkNavy">
    <div class="swiper heroSwiper absolute inset-0 z-0">
        <div class="swiper-wrapper">
            <div class="swiper-slide"><img src="/images/01 AERIAL VIEW.jpg" class="w-full h-full object-cover opacity-60" alt="Aerial View"></div>
            <div class="swiper-slide"><img src="/images/02 MES_01.jpg" class="w-full h-full object-cover opacity-60" alt="Medical Engineering"></div>
            <div class="swiper-slide"><img src="/images/hero.jpg" class="w-full h-full object-cover opacity-60" alt="FMRT Center"></div>
        </div>
    </div>
    
    <div class="hero-gradient-overlay absolute inset-0 z-10"></div>
    
    <div class="relative z-20 w-full py-16 sm:py-24 lg:py-0">
        <div class="max-w-7xl mx-auto px-4 sm:px-8 lg:px-16">
            <div class="max-w-3xl">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-8 h-[2px] bg-iitkTeal"></div>
                    <span class="uppercase tracking-[0.3em] text-iitkbluelight text-xs font-bold">IITK Foundation for Medical Research and Technology</span>
                </div>
                <h1 class="text-white font-heading font-black leading-[1.1] text-4xl sm:text-5xl lg:text-7xl tracking-tight">
                    Where <span class="text-iitkbluelight">Engineering</span> <br class="hidden sm:inline">Meets Medicine
                </h1>
                <p class="text-gray-300 font-normal text-xl lg:text-2xl mt-4">for a Healthier India.</p>
                <p class="text-gray-300 text-base sm:text-lg leading-relaxed mt-6 max-w-xl">
                    IITK Foundation for Medical Research & Technology is pioneering a new era where engineering excellence, translational research, and compassionate clinical care converge.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 mt-10 pb-15 lg:pb-20">
                    <a href="/about" class="btn-primary px-8 py-4 rounded-lg bg-gradient-to-r from-[#063f8e] to-[#207ce5] text-white shadow-lg shadow-[#207ce5]/40 rounded-full px-6 py-2 font-bold border-2 border-[#60AEFF] text-center font-bold">Discover Our Story</a>
                    <a href="/contact" class="px-8 py-4 rounded-lg border border-white/40 text-white text-center font-bold hover:bg-white hover:text-iitkNavy transition duration-300">Contact Us</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="relative z-30 max-w-7xl mx-auto px-4 sm:px-8 lg:px-16 -mt-10 sm:-mt-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
